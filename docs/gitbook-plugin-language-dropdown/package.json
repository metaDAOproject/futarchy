{
  "name": "gitbook-plugin-language-dropdown",
  "version": "1.0.0",
  "description": "A custom language dropdown plugin for GitBook",
  "engines": {
    "gitbook": ">3.0.0"
  },
  "gitbook": {
    "properties": {
      "languages": {
        "type": "array",
        "default": [],
        "description": "List of available languages"
      }
    }
  }
}
